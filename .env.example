# Copy this file to .env and fill in your own values.
# Never commit your real .env file to version control.

# ---------------------------------------------------------------------------
# REQUIRED: OpenAI API
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here

# Chat model used for generation (coverage assessment, fraud scoring)
LLM_MODEL=gpt-4o-mini

# Embedding model used for chunk + query embeddings
EMBEDDING_MODEL=text-embedding-3-small

# Sampling temperature for the LLM (keep low/0 for consistent, grounded output)
LLM_TEMPERATURE=0.0

# ---------------------------------------------------------------------------
# Chunking configuration
# ---------------------------------------------------------------------------
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# ---------------------------------------------------------------------------
# Retrieval configuration
# ---------------------------------------------------------------------------
RETRIEVER_TOP_K=5
CHROMA_COLLECTION_NAME=claimwise_policies

# ---------------------------------------------------------------------------
# Guardrail thresholds
# ---------------------------------------------------------------------------
MIN_CONFIDENCE_FOR_ASSESSMENT=0.35
LOW_CONTEXT_CHAR_THRESHOLD=200

# ---------------------------------------------------------------------------
# PII masking (bonus feature)
# ---------------------------------------------------------------------------
ENABLE_PII_MASKING=true

# ---------------------------------------------------------------------------
# OPTIONAL: LangSmith observability (bonus feature)
# Sign up at https://smith.langchain.com to get an API key.
# ---------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=claimwise-ai
